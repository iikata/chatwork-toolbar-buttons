{
  "manifest_version": 3,
  "name": "ChatWork ツールバーボタン",
  "version": "1.0.0",
  "description": "ChatWorkのツールバーに[info][title]、[info]、[hr]タグのボタンを追加します",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.chatwork.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
